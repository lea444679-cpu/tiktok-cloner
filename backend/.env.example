# Clé API Anthropic (Claude) - pour analyser le hook/structure et générer le nouveau script
# https://console.anthropic.com -> quelques centimes par vidéo avec Claude Haiku
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Clé API Pexels (GRATUITE) - pour récupérer des vidéos/images de b-roll
# https://www.pexels.com/api/ -> inscription gratuite, quota généreux
PEXELS_API_KEY=xxxxx

# Dossier de stockage temporaire des fichiers vidéo générés
STORAGE_DIR=./storage

# Port du serveur
PORT=8000
